# ─────────────────────────────────────────────
# Core — .env.example
# Copy to .env and fill in your API keys.
# ─────────────────────────────────────────────

# ── Gemini (required) ─────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
CLASSIFIER_MODEL=models/gemini-2.5-flash
LLM_PARSER_MODEL=models/gemini-2.5-flash

# ── OpenRouter (optional fallback) ────────────
# OPENROUTER_API_KEY=your_openrouter_api_key

# ── 9router (optional local proxy) ────────────
# NINEROUTER_API_KEY=your_ninerouter_api_key
# NINEROUTER_MODEL=anthropic/claude-sonnet-4.5
# NINEROUTER_URL=https://api.9router.com/v1/chat/completions

# ── Provider priority ─────────────────────────
# gemini | openrouter | 9router
CODE_GEN_PROVIDER=gemini
